# ──────────────────────────────────────────────
#  proxy-chunk-speedup .gitignore
# ──────────────────────────────────────────────

# ── User config (contains real proxy URLs — never commit) ──
config.yaml

# ── Downloaded / cached proxy lists (ephemeral, large) ──
free-proxy-list.txt
*.proxy-list.txt
proxies.txt

# ── Python runtime ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ──
.venv/
venv/
env/
.env/
ENV/

# ── pip / uv / poetry / pipenv ──
pip-log.txt
pip-delete-this-directory.txt
uv.lock
Poetry.lock
Pipfile.lock

# ── IDE / editor ──
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS artefacts ──
.DS_Store
Thumbs.db
desktop.ini

# ── Tor data directories ──
tor_data/
tor_data_*/

# ── Disk cache (sqlite3 WAL files) ──
*.db
*.db-wal
*.db-shm

# ── Logs ──
*.log
logs/

# ── Test / coverage ──
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Secrets / local overrides ──
.env
*.env
secrets.yaml
*.secret.*
